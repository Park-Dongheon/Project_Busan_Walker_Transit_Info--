# 기본: 텍스트는 LF로 통일(협업/CI에서 충돌 최소화)
* text=auto eol=lf

# Maven Wrapper
/mvnw text eol=lf
*.cmd text eol=crlf

# Windows scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

# Shell scripts
*.sh text eol=lf

# Binary files (diff/merge 방지)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary